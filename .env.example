# Golemio API token — publicly exposed in odpady.mojepraha.eu/env-config.js
VITE_GOLEMIO_TOKEN=

# Search radius in meters (default on official site: 2000)
VITE_GOLEMIO_RANGE=2000

# Web Push (generate with: npm run generate-vapid)
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Vercel Cron auth (random string, also set in Vercel env)
CRON_SECRET=

# Upstash Redis (from Vercel → Marketplace → Upstash Redis integration)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
